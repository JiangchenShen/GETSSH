{
  "name": "getssh",
  "version": "2.0.0-R7K4S",
  "main": "dist-electron/main/index.js",
  "description": "Electron React SSH Client with Glassmorphism",
  "author": "Shen Jiangchen <shenjiangchen@example.com>",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:watchdog && vite build && electron-builder",
    "build:watchdog": "cd ../../rust-core/watchdog && cargo build --release",
    "build:plugin": "node scripts/package-plugin.js",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.30.0",
    "@moovier/core": "workspace:*",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.40.0",
    "fuse.js": "^7.4.0",
    "immer": "^11.1.8",
    "node-pty": "^1.1.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.19",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.11.19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "archiver": "^8.0.0",
    "dompurify": "^3.4.7",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "http-proxy-agent": "^9.0.0",
    "i18next": "^26.0.7",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.17.0",
    "p-limit": "^7.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.4",
    "socks": "^2.8.9",
    "tailwindcss": "4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^4.1.6",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.getssh.app",
    "productName": "GETSSH",
    "npmRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "JiangchenShen",
      "repo": "GETSSH"
    },
    "electronLanguages": [
      "en-US",
      "zh-CN"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "directories": {
      "buildResources": "build"
    },
    "asar": true,
    "asarUnpack": [
      "../../rust-core/**/*"
    ],
    "extraResources": [
      {
        "from": "../../target/release/watchdog",
        "to": "watchdog"
      },
      {
        "from": "../../target/release/watchdog.exe",
        "to": "watchdog.exe"
      }
    ],
    "files": [
      "dist/index.html",
      "dist/assets/**/*",
      "dist/plugins/**/*",
      "!dist/plugins/test-plugin/**/*",
      "dist-electron/**/*",
      "../../rust-core/**/*.node",
      "../../rust-core/**/*.js",
      "../../rust-core/**/package.json",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsx",
      "!**/*.md",
      "!**/*.txt",
      "!**/LICENSE*",
      "!**/CHANGELOG*",
      "!**/test/**",
      "!**/tests/**",
      "!**/__tests__/**",
      "!**/docs/**",
      "!**/example/**",
      "!**/examples/**",
      "!**/.github/**",
      "!**/node_modules/.cache/**",
      "!../../rust-core/**/node_modules/**",
      "!**/node_env/**",
      "!**/sftp-mock-plugin/**",
      "!**/@types/**",
      "!**/.DS_Store",
      "!src/**/*"
    ],
    "mac": {
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "title": "Install GETSSH",
      "format": "ULFO",
      "background": "build/background.png",
      "contents": [
        {
          "x": 130,
          "y": 180
        },
        {
          "x": 410,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "uninstallDisplayName": "GETSSH Uninstaller",
      "shortcutName": "GETSSH",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-builder",
      "node-pty",
      "esbuild"
    ]
  }
}
