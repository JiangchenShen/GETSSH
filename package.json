{
  "name": "getssh",
  "version": "1.2.1",
  "main": "dist-electron/main/index.js",
  "description": "Electron React SSH Client with Glassmorphism",
  "author": "Shen Jiangchen <shenjiangchen@example.com>",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test": "vitest"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "dompurify": "^3.4.2",
    "http-proxy-agent": "^9.0.0",
    "socks": "^2.8.7",
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.8",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/ssh2": "^1.11.19",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.16",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "i18next": "^26.0.7",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.300.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.4",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-electron": "^0.15.5",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.5",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-webgl": "^0.16.0",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.getssh.app",
    "productName": "GETSSH",
    "directories": {
      "buildResources": "build"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/ssh2/**/*.node",
      "node_modules/cpu-features/**/*.node"
    ],
    "files": [
      "dist/index.html",
      "dist/assets/**/*",
      "dist-electron/**/*",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsx",
      "!**/*.md",
      "!**/*.txt",
      "!**/LICENSE*",
      "!**/CHANGELOG*",
      "!**/test/**",
      "!**/tests/**",
      "!**/__tests__/**",
      "!**/docs/**",
      "!**/example/**",
      "!**/examples/**",
      "!**/.github/**",
      "!**/node_modules/.cache/**",
      "!**/node_env/**",
      "!**/sftp-mock-plugin/**",
      "!**/@types/**",
      "!**/.DS_Store"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "title": "Install GETSSH",
      "background": "build/background.png",
      "contents": [
        {
          "x": 130,
          "y": 180
        },
        {
          "x": 410,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "uninstallDisplayName": "GETSSH Uninstaller",
      "shortcutName": "GETSSH",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    }
  }
}
